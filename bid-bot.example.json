{
  "_comment": "이 파일을 bid-bot.json으로 복사한 뒤 내 validator 값만 채워서 사용하세요. bid-bot.json은 git에 올리지 않습니다.",

  "validator": {
    "_comment": "내 validator 계정과 서명 keypair 설정입니다. voteAccount는 필수이고, 실전 적용에는 authFile/keypairFile이 필요합니다.",
    "voteAccount": "",
    "bondAccount": "",
    "authFile": "./keys/keypair.json",
    "keypairFile": "./keys/keypair.json"
  },

  "dssam": {
    "_comment": "Marinade SAM 계산용 로컬 폴더입니다. 보통 기본값 그대로 두면 됩니다.",
    "dir": "./ds-sam",
    "pipelineDir": "./ds-sam-pipeline",
    "cacheDir": "./ds-sam-cache",
    "outputDir": "./ds-sam-output",
    "heavyCacheTtl": 86400
  },

  "bidStrategy": {
    "_comment": "자동 bid 조정 안전장치입니다. 처음에는 기본값으로 시작하는 것을 권장합니다.",
    "safetyRatio": 1.025,
    "winBufferPmpe": 0.0005,
    "permittedDev": 0.01,
    "minBidChangePmpe": 0.0005,
    "minSanityBid": 0.005,
    "maxSanityBid": 0.20,
    "maxSingleDrop": 0.02
  },

  "logging": {
    "logFile": "./bid-bot.log",
    "stateFile": "./bid-bot.state",
    "discordWebhook": ""
  },

  "runtime": {
    "_comment": "처음에는 dryRun=true로 로그만 확인하고, 충분히 검증한 뒤 false로 바꾸세요.",
    "dryRun": true,
    "loopInterval": 3600,
    "epochAware": {
      "enabled": true,
      "thresholdSeconds": 3600,
      "fastLoopIntervalSeconds": 300,
      "solanaRpcUrl": "https://api.mainnet-beta.solana.com",
      "rpcTimeoutMs": 10000
    },
    "dsSamTimeoutMs": 300000,
    "bondCliTimeoutMs": 60000,
    "setupCommandTimeoutMs": 900000
  }
}

{
  "_comment": "bid-bot 설정 파일. 우선순위: 환경변수 > 이 JSON > 스크립트 default",

  "validator": {
    "_comment": "voteAccount, authFile, keypairFile은 필수. 본인 값으로 채우세요",
    "voteAccount": "",
    "authFile": "",
    "keypairFile": ""
  },

  "dssam": {
    "_comment": "ds-sam 로컬 실행 환경. 자동으로 clone + install 됨",
    "dir": "./ds-sam",
    "pipelineDir": "./ds-sam-pipeline",
    "cacheDir": "./ds-sam-cache",
    "outputDir": "./ds-sam-output",
    "heavyCacheTtl": 86400
  },

  "bidStrategy": {
    "_comment": "target = max(effPart×safetyRatio, effPart+winBuffer, effPart×(1-permittedDev))",
    "safetyRatio": 1.05,
    "winBufferPmpe": 0.0005,
    "permittedDev": 0.01,
    "minBidChangePmpe": 0.0005,
    "minSanityBid": 0.005,
    "maxSanityBid": 0.20,
    "maxSingleDrop": 0.02,
    "maxStakeSol": 80000
  },

  "logging": {
    "logFile": "./bid-bot.log",
    "stateFile": "./bid-bot.state",
    "discordWebhook": ""
  },

  "runtime": {
    "_comment": "dryRun=true면 실제 변경 안 함",
    "dryRun": false,
    "loopInterval": 300
  }
}
